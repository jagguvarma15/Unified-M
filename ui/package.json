{
  "name": "unified-m-ui",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typegen:api": "python3 ../scripts/export_openapi.py --out ./openapi.json && openapi-typescript ./openapi.json -o ./src/lib/api.generated.ts",
    "check:api-types": "bun run typegen:api && test -s ./src/lib/api.generated.ts",
    "check:bundle": "bun run build && node ./scripts/check-budgets.mjs"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-window": "^1.8.10",
    "react-router-dom": "^6.28.0",
    "recharts": "^3.7.0",
    "lucide-react": "^0.460.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "~5.6.2",
    "vite": "^7.3.1",
    "openapi-typescript": "^7.10.1"
  }
}
